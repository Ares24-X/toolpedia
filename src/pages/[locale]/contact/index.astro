---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../i18n/translations';

export function getStaticPaths() {
  const locales = ['en', 'ja', 'de', 'es'];
  return locales.map(locale => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props;
const t = siteConfig[locale];

const content: Record<string, { title: string; body: string; email: string }> = {
  en: { title: 'Contact Us', body: 'Have a question, suggestion, or want to report an issue? Send us an email:', email: 'hello@toolpedia.win' },
  ja: { title: 'お問い合わせ', body: 'ご質問、ご提案、問題の報告はこちらまで：', email: 'hello@toolpedia.win' },
  de: { title: 'Kontakt', body: 'Haben Sie eine Frage oder einen Vorschlag? Schreiben Sie uns eine E-Mail:', email: 'hello@toolpedia.win' },
  es: { title: 'Contacto', body: '¿Tiene una pregunta o sugerencia? Envíenos un correo electrónico:', email: 'hello@toolpedia.win' },
};

const c = content[locale] || content.en;
---

<BaseLayout locale={locale} title={`${c.title} — ToolPedia`} description={c.title}>
  <article style="max-width:720px;margin:0 auto;padding:40px 0;text-align:center">
    <h1>{c.title}</h1>
    <p style="font-size:1.1rem;margin-bottom:24px">{c.body}</p>
    <a href={`mailto:${c.email}`} style="display:inline-block;font-size:1.2rem;font-weight:600;color:#2563eb;padding:12px 24px;border:2px solid #2563eb;border-radius:8px;">
      {c.email}
    </a>
  </article>
</BaseLayout>
