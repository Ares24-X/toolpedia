---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../i18n/translations';

export function getStaticPaths() {
  const locales = ['en', 'ja', 'de', 'es'];
  return locales.map(locale => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props;
const t = siteConfig[locale];

const content: Record<string, { title: string; sections: { h: string; p: string }[] }> = {
  en: {
    title: 'Terms of Service',
    sections: [
      { h: 'Acceptance of Terms', p: 'By using ToolPedia, you agree to these Terms of Service. If you do not agree, do not use the site.' },
      { h: 'Use of Content', p: 'All content on this site is for informational purposes only. We make no guarantees about accuracy, completeness, or timeliness of any content.' },
      { h: 'Affiliate Disclosure', p: 'Some links on this site are affiliate links. If you click and make a purchase, we may earn a commission at no extra cost to you. This does not affect our editorial independence.' },
      { h: 'Intellectual Property', p: 'Original content on ToolPedia is our property. You may share or cite it with attribution. You may not reproduce substantial portions without permission.' },
      { h: 'Limitation of Liability', p: 'ToolPedia is provided "as is." We are not liable for any damages arising from use of this site or linked third-party services.' },
      { h: 'Changes', p: 'We may update these terms. Continued use after changes constitutes acceptance.' },
    ],
  },
  ja: {
    title: '利用規約',
    sections: [
      { h: '規約の承諾', p: 'ToolPediaをご利用になることで、これらの利用規約に同意したものとみなされます。' },
      { h: 'コンテンツの利用', p: 'このサイトのすべてのコンテンツは情報提供のみを目的としています。正確性、完全性、最新性を保証しません。' },
      { h: 'アフィリエイト開示', p: '一部のリンクはアフィリエイトリンクです。リンクをクリックして購入された場合、追加費用なしで手数料を得る場合があります。' },
      { h: '知的財産', p: 'ToolPediaのオリジナルコンテンツは当社の財産です。帰属表示付きで共有または引用することができます。' },
      { h: '責任の制限', p: 'ToolPediaは「現状のまま」提供されます。本サイトの使用から生じる損害について責任を負いません。' },
      { h: '変更', p: 'これらの規約は更新される場合があります。変更後も継続して使用することで承諾したものとみなされます。' },
    ],
  },
  de: {
    title: 'Nutzungsbedingungen',
    sections: [
      { h: 'Annahme der Bedingungen', p: 'Durch die Nutzung von ToolPedia stimmen Sie diesen Nutzungsbedingungen zu.' },
      { h: 'Nutzung von Inhalten', p: 'Alle Inhalte dienen nur zu Informationszwecken. Wir garantieren keine Richtigkeit oder Vollständigkeit.' },
      { h: 'Affiliate-Offenlegung', p: 'Einige Links sind Affiliate-Links. Bei einem Kauf über diese Links erhalten wir eine Provision ohne Mehrkosten für Sie.' },
      { h: 'Geistiges Eigentum', p: 'Originalinhalte auf ToolPedia sind unser Eigentum. Sie dürfen sie mit Quellenangabe teilen.' },
      { h: 'Haftungsbeschränkung', p: 'ToolPedia wird "wie besehen" bereitgestellt. Wir haften nicht für Schäden aus der Nutzung.' },
      { h: 'Änderungen', p: 'Diese Bedingungen können aktualisiert werden.' },
    ],
  },
  es: {
    title: 'Términos de Servicio',
    sections: [
      { h: 'Aceptación de Términos', p: 'Al usar ToolPedia, acepta estos Términos de Servicio.' },
      { h: 'Uso del Contenido', p: 'Todo el contenido es solo informativo. No garantizamos precisión o integridad.' },
      { h: 'Divulgación de Afiliados', p: 'Algunos enlaces son de afiliados. Podemos recibir una comisión sin costo adicional para usted.' },
      { h: 'Propiedad Intelectual', p: 'El contenido original es de nuestra propiedad. Puede compartirlo con atribución.' },
      { h: 'Limitación de Responsabilidad', p: 'ToolPedia se proporciona "tal cual". No somos responsables por daños derivados de su uso.' },
      { h: 'Cambios', p: 'Estos términos pueden actualizarse.' },
    ],
  },
};

const c = content[locale] || content.en;
---

<BaseLayout locale={locale} title={`${c.title} — ToolPedia`} description={c.title}>
  <article style="max-width:720px;margin:0 auto;padding:24px 0">
    <h1>{c.title}</h1>
    <p style="color:#94a3b8;font-size:.9rem">Last updated: June 5, 2026</p>
    {c.sections.map(s => (
      <div style="margin-bottom:28px">
        <h3>{s.h}</h3>
        <p>{s.p}</p>
      </div>
    ))}
  </article>
</BaseLayout>
