---
import type { Locale } from '../i18n/translations';
import { siteConfig } from '../i18n/translations';

// Pillar configs with emoji icons & colors
const pillarConfig: Record<string, { icon: string; color: string; bg: string }> = {
  reviews:  { icon: '🔍', color: '#2563eb', bg: '#eef4ff' },
  tutorials:{ icon: '📖', color: '#7c3aed', bg: '#f3eeff' },
  pdf:      { icon: '📄', color: '#dc2626', bg: '#feeef0' },
  design:   { icon: '🎨', color: '#0891b2', bg: '#ecfeff' },
  trends:   { icon: '📈', color: '#059669', bg: '#ecfdf5' },
};

const { locale, title, description } = Astro.props;
const t = siteConfig[locale];
const pillars = ['reviews', 'tutorials', 'pdf', 'design', 'trends'];
const pillarNames: Record<string, string> = {
  reviews: t.nav.reviews, tutorials: t.nav.tutorials, pdf: t.nav.pdf,
  design: t.nav.design, trends: t.nav.trends,
};
const altLocales = (['en', 'ja', 'de', 'es'] as Locale[]).filter(l => l !== locale);
const displayLang: Record<string, string> = { en: 'English', ja: '日本語', de: 'Deutsch', es: 'Español' };
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}{title.includes('ToolPedia') ? '' : ' — ToolPedia'}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛠️</text></svg>" />
  {altLocales.map(l => (
    <link rel="alternate" hreflang={l} href={`https://toolpedia.win/${l}/`} />
  ))}
  <style is:global>
    /* Reset */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      line-height: 1.7;
      color: #1e293b;
      background: #f8fafc;
    }
    img { max-width: 100%; height: auto; }
    a { color: #2563eb; text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* Container */
    .container { max-width: 960px; margin: 0 auto; padding: 0 20px; }
    @media (max-width: 640px) { .container { padding: 0 16px; } }

    /* === Header / Nav === */
    .site-header {
      background: #fff;
      border-bottom: 1px solid #e2e8f0;
      position: sticky; top: 0; z-index: 100;
    }
    .header-inner {
      display: flex; align-items: center; justify-content: space-between;
      height: 64px; max-width: 960px; margin: 0 auto; padding: 0 20px;
    }
    .site-logo {
      font-size: 1.4rem; font-weight: 800; color: #0f172a;
      display: flex; align-items: center; gap: 6px;
    }
    .site-logo span { background: linear-gradient(135deg, #2563eb, #7c3aed); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    /* Desktop nav */
    .nav-main { display: flex; align-items: center; gap: 24px; }
    .nav-main a {
      font-size: .9rem; color: #475569; font-weight: 500; white-space: nowrap;
      transition: color .15s;
    }
    .nav-main a:hover { color: #2563eb; text-decoration: none; }
    .nav-main a.active { color: #2563eb; }

    /* Lang dropdown (desktop) */
    .lang-wrap { position: relative; }
    .lang-current {
      display: flex; align-items: center; gap: 4px;
      background: #f1f5f9; padding: 6px 12px; border-radius: 6px;
      font-size: .85rem; color: #475569; cursor: pointer; border: none;
    }
    .lang-current:hover { background: #e2e8f0; }
    .lang-dropdown {
      display: none; position: absolute; top: 100%; right: 0; margin-top: 4px;
      background: #fff; border: 1px solid #e2e8f0; border-radius: 8px;
      box-shadow: 0 4px 12px rgba(0,0,0,.1); overflow: hidden; min-width: 140px;
    }
    .lang-wrap:hover .lang-dropdown,
    .lang-wrap:focus-within .lang-dropdown { display: block; }
    .lang-dropdown a {
      display: block; padding: 10px 16px; font-size: .9rem; color: #334155;
    }
    .lang-dropdown a:hover { background: #f1f5f9; text-decoration: none; }
    .lang-dropdown a.active { background: #eef4ff; color: #2563eb; font-weight: 600; }

    /* Hamburger */
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; }
    .hamburger span { display: block; width: 24px; height: 2px; background: #334155; border-radius: 2px; transition: .2s; }

    /* Mobile nav (hidden by default) */
    .nav-mobile {
      display: none; background: #fff; border-bottom: 1px solid #e2e8f0;
      padding: 12px 20px 16px;
    }
    .nav-mobile.open { display: block; }
    .nav-mobile a {
      display: block; padding: 10px 0; font-size: 1rem; color: #334155; font-weight: 500;
      border-bottom: 1px solid #f1f5f9;
    }
    .nav-mobile a:last-child { border-bottom: none; }
    .nav-mobile .lang-row { display: flex; gap: 12px; margin-top: 12px; flex-wrap: wrap; }
    .nav-mobile .lang-row a {
      border: none; background: #f1f5f9; padding: 6px 14px; border-radius: 6px; font-size: .85rem;
    }
    .nav-mobile .lang-row a.active { background: #2563eb; color: #fff; }

    @media (max-width: 768px) {
      .nav-main, .lang-wrap { display: none; }
      .hamburger { display: flex; }
    }

    /* === Main === */
    main { min-height: 60vh; padding: 32px 0; }
    @media (max-width: 640px) { main { padding: 20px 0; } }

    /* === Typography === */
    h1 { font-size: 2.2rem; font-weight: 800; line-height: 1.3; color: #0f172a; margin-bottom: 12px; }
    h2 { font-size: 1.6rem; font-weight: 700; color: #0f172a; margin: 36px 0 12px; }
    h3 { font-size: 1.2rem; font-weight: 600; color: #1e293b; margin: 24px 0 8px; }
    p { margin-bottom: 16px; color: #475569; }
    @media (max-width: 640px) {
      h1 { font-size: 1.6rem; }
      h2 { font-size: 1.3rem; }
    }

    /* === Cards === */
    .card {
      background: #fff; border-radius: 12px; padding: 24px;
      border: 1px solid #e2e8f0; transition: box-shadow .2s, transform .15s;
    }
    .card:hover { box-shadow: 0 4px 12px rgba(0,0,0,.06); }

    /* Article card */
    .article-card {
      background: #fff; border-radius: 12px; padding: 20px 24px; margin-bottom: 12px;
      border: 1px solid #e2e8f0; transition: box-shadow .2s, border-color .2s;
    }
    .article-card:hover { border-color: #cbd5e1; box-shadow: 0 2px 8px rgba(0,0,0,.04); }
    .article-card h2 { margin: 6px 0 8px; }
    .article-card h2 a { color: #0f172a; font-size: 1.1rem; }
    .article-card h2 a:hover { color: #2563eb; text-decoration: none; }
    .article-card p { color: #64748b; font-size: .9rem; margin: 0; line-height: 1.6; }
    .article-meta { display: flex; align-items: center; gap: 8px; font-size: .8rem; color: #94a3b8; }

    .tag {
      display: inline-block; font-size: .7rem; font-weight: 600; text-transform: uppercase;
      padding: 2px 8px; border-radius: 4px; letter-spacing: .3px;
    }

    /* Category grid cards */
    .cat-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
    .cat-card {
      display: flex; flex-direction: column; align-items: center; gap: 6px;
      padding: 20px 12px; border-radius: 12px; border: 1px solid #e2e8f0;
      background: #fff; transition: .2s; cursor: pointer; text-decoration: none;
    }
    .cat-card:hover { border-color: #cbd5e1; box-shadow: 0 4px 12px rgba(0,0,0,.06); text-decoration: none; }
    .cat-card .icon { font-size: 1.8rem; }
    .cat-card .name { font-size: .8rem; font-weight: 600; color: #1e293b; text-align: center; }
    .cat-card .count { font-size: .7rem; color: #94a3b8; }

    @media (max-width: 640px) {
      .cat-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
      .cat-card { padding: 16px 10px; }
      .article-card { padding: 16px; }
    }

    /* === Buttons === */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 10px 20px; border-radius: 8px; font-weight: 600; font-size: .9rem;
      transition: .15s; cursor: pointer; border: none;
    }
    .btn-primary { background: linear-gradient(135deg, #2563eb, #7c3aed); color: #fff; }
    .btn-primary:hover { box-shadow: 0 4px 12px rgba(37,99,235,.3); transform: translateY(-1px); text-decoration: none; color: #fff; }
    .btn-outline { background: transparent; border: 1.5px solid #2563eb; color: #2563eb; }
    .btn-outline:hover { background: #eef4ff; text-decoration: none; }

    /* == Article page specific == */
    .article-hero { padding: 32px 0 16px; }
    .article-hero .meta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
    .article-body { font-size: 1rem; line-height: 1.8; }
    .article-body p { margin-bottom: 20px; }
    .article-body ul, .article-body ol { margin-bottom: 20px; padding-left: 24px; }
    .article-body li { margin-bottom: 8px; }
    .article-body table { width: 100%; border-collapse: collapse; margin: 20px 0; font-size: .9rem; }
    .article-body th, .article-body td { border: 1px solid #e2e8f0; padding: 10px 14px; text-align: left; }
    .article-body th { background: #f8fafc; font-weight: 600; }
    .article-body blockquote {
      border-left: 3px solid #2563eb; padding: 14px 20px; margin: 20px 0;
      background: #f0f7ff; border-radius: 0 8px 8px 0;
    }
    .article-body blockquote p { margin: 0; }
    @media (max-width: 640px) { .article-body { font-size: .95rem; } }

    /* CTA Box */
    .cta-box {
      background: linear-gradient(135deg, #0f172a, #1e293b); color: #fff;
      padding: 28px; border-radius: 12px; margin: 28px 0; text-align: center;
    }
    .cta-box h3 { color: #fff; font-size: 1.2rem; margin-bottom: 8px; }
    .cta-box p { color: #cbd5e1; margin-bottom: 16px; }
    .cta-box a { color: #facc15; font-weight: 600; }
    .cta-box a:hover { color: #fde047; }

    /* === Footer === */
    .site-footer {
      background: #0f172a; color: #94a3b8; padding: 40px 0 32px; margin-top: 48px;
    }
    .footer-inner { max-width: 960px; margin: 0 auto; padding: 0 20px; }
    .footer-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .footer-col h4 { color: #fff; font-size: .85rem; font-weight: 600; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px; }
    .footer-col a { display: block; color: #94a3b8; font-size: .85rem; padding: 4px 0; }
    .footer-col a:hover { color: #fff; text-decoration: none; }
    .footer-bottom { text-align: center; padding-top: 24px; margin-top: 24px; border-top: 1px solid #1e293b; font-size: .85rem; }
    @media (max-width: 640px) { .footer-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; } }

    /* === Pillar page specific === */
    .pillar-header { padding: 24px 0; }
    .pillar-header h1 { display: flex; align-items: center; gap: 12px; }
    .pillar-header .pillar-icon { font-size: 2rem; }
    .pillar-header p { color: #64748b; max-width: 600px; }
    .articles-list { margin-top: 8px; }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/{locale}/" class="site-logo">
        🛠️ <span>ToolPedia</span>
      </a>
      <nav class="nav-main">
        {pillars.map(p => (
          <a href={`/${locale}/${p}/`} class={Astro.url.pathname.includes(`/${locale}/${p}/`) ? 'active' : ''}>
            {pillarConfig[p].icon} {pillarNames[p]}
          </a>
        ))}
      </nav>
      <div class="lang-wrap">
        <button class="lang-current">
          🌐 {locale.toUpperCase()}
          <span style="font-size:.7rem">▾</span>
        </button>
        <div class="lang-dropdown">
          {altLocales.concat([locale]).sort().map(l => (
            <a href={`/${l}/`} class={l === locale ? 'active' : ''}>{displayLang[l]}</a>
          ))}
        </div>
      </div>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
    <!-- Mobile nav -->
    <div class="nav-mobile" id="navMobile">
      {pillars.map(p => (
        <a href={`/${locale}/${p}/`}>{pillarConfig[p].icon} {pillarNames[p]}</a>
      ))}
      <div class="lang-row">
        {['en', 'ja', 'de', 'es'].map(l => (
          <a href={`/${l}/`} class={l === locale ? 'active' : ''}>{displayLang[l]}</a>
        ))}
      </div>
    </div>
  </header>

  <!-- Main -->
  <main>
    <div class="container">
      <slot />
    </div>
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>{t.siteTitle}</h4>
          <p style="font-size:.85rem;line-height:1.6">{t.siteDesc}</p>
        </div>
        <div class="footer-col">
          <h4>{t.footer.categories}</h4>
          {pillars.map(p => (
            <a href={`/${locale}/${p}/`}>{pillarConfig[p].icon} {pillarNames[p]}</a>
          ))}
        </div>
        <div class="footer-col">
          <h4>{t.footer.languages}</h4>
          {['en', 'ja', 'de', 'es'].map(l => (
            <a href={`/${l}/`}>{displayLang[l]}</a>
          ))}
        </div>
        <div class="footer-col">
          <h4>{t.footer.legal}</h4>
          <a href={`/${locale}/privacy/`}>{t.pages.privacy}</a>
          <a href={`/${locale}/terms/`}>{t.pages.terms}</a>
          <a href={`/${locale}/about/`}>{t.pages.about}</a>
          <a href={`/${locale}/contact/`}>{t.pages.contact}</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 ToolPedia. {t.footer.disclaimer}</p>
      </div>
    </div>
  </footer>

  <!-- Hamburger toggle -->
  <script>
    document.getElementById('hamburger')?.addEventListener('click', () => {
      document.getElementById('navMobile')?.classList.toggle('open');
    });
  </script>
</body>
</html>
